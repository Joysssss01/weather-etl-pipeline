          "rawQuery": true,
          "rawSql": "SELECT\r\n  CAST(DATETIME(f.target_time) AS TIMESTAMP) AS time,\r\n  f.pred_temp AS temperature,\r\n  d.city_name AS city\r\nFROM `project-12c56ec2-0f93-4ccd-a36.weather_data.fact_forecasts` AS f\r\nJOIN `project-12c56ec2-0f93-4ccd-a36.weather_data.dim_cities` AS d \r\n  ON f.city_id = d.city_id\r\nWHERE\r\n  -- 這裡串連你設定好的 4 個變數\r\n  d.continent IN (${continent:sqlstring})\r\n  AND d.country IN (${country:sqlstring})\r\n  AND d.city_name IN (${city:sqlstring})\r\n  AND f.forecast_date = CAST('${date}' AS DATE)\r\nORDER BY f.target_time ASC",
